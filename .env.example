# Database
POSTGRES_PASSWORD=wodgod_dev
DB_PORT=5432

# Backend API
API_PORT=8000

# JWT Authentication
JWT_SECRET=change-me-in-production
JWT_EXPIRE_HOURS=72

# LLM Configuration
# Provider: "ollama" or "openai_compatible"
LLM_PROVIDER=ollama
LLM_BASE_URL=http://host.docker.internal:11434
LLM_MODEL=llama3

# For OpenAI-compatible APIs (e.g. local vLLM, text-generation-inference)
# LLM_PROVIDER=openai_compatible
# LLM_BASE_URL=http://host.docker.internal:8080
# LLM_MODEL=meta-llama/Meta-Llama-3-8B-Instruct
# LLM_API_KEY=your-api-key-if-needed
